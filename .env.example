# ===== API Keys =====
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
BROWSER_USE_API_KEY=

# ===== Optional Endpoints =====
OLLAMA_BASE_URL=http://localhost:11434
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BROWSER_USE_LLM_URL=https://llm.api.browser-use.com
BROWSER_USE_CLOUD_API_URL=https://api.browser-use.com
BROWSER_USE_CLOUD_SYNC=true
BROWSER_USE_CONFIG_DIR=.browseruse
BROWSER_USE_USE_CLOUD_BROWSER=false
BROWSER_USE_USE_JUDGE=false
BROWSER_USE_CLOUD_PROFILE_ID=
BROWSER_USE_CLOUD_PROXY_COUNTRY_CODE=
BROWSER_USE_CLOUD_TIMEOUT=
# ===== MCP / Runtime =====
MCP_SERVER_NAME=AI-Crawler-Agent
THREAD_PREFIX=mcp_task
INTERRUPT_BEFORE_BROWSER=false
DEFAULT_MAX_PAGES=3
RETRY_LIMIT=3
MAX_CONCURRENT_TASKS=3
DEFAULT_SCRAPE_TIMEOUT=90
DATA_DIR=data
BUSINESS_DB_PATH=
LOG_LEVEL=INFO
LOG_DIR=data/logs

# ===== Browser Behavior =====
HEADLESS=true
SLOW_MO=500

# ===== Scene Models =====
BROWSER_PROVIDER=browser-use
BROWSER_MODEL_NAME=bu-latest
BROWSER_TEMPERATURE=0.0

ANALYST_PROVIDER=openai
ANALYST_MODEL_NAME=gpt-4o-mini
ANALYST_TEMPERATURE=0.2

GENERAL_PROVIDER=openai
GENERAL_MODEL_NAME=gpt-4o-mini
GENERAL_TEMPERATURE=0.0
